{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "moduleResolution": "node",
    "allowJs": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "isolatedModules": true,
    "checkJs": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src"]
}